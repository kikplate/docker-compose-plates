{{ if .modules.postgres.enabled }}
include:
  - docker-compose.postgres.yml
{{ end }}
services:
  keycloak:
    image: quay.io/keycloak/keycloak:{{ .keycloakVersion }}
    container_name: {{ .projectName }}-keycloak
    restart: unless-stopped
    stop_grace_period: 60s
    security_opt:
      - no-new-privileges:true
    command: start-dev
    env_file:
      - .env
    environment:
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://postgres:5432/keycloak
      KC_DB_USERNAME: ${POSTGRES_USER}
      KC_DB_PASSWORD: ${POSTGRES_PASSWORD}
      KEYCLOAK_ADMIN: ${KEYCLOAK_ADMIN}
      KEYCLOAK_ADMIN_PASSWORD: ${KEYCLOAK_ADMIN_PASSWORD}
      KC_HTTP_PORT: 8080
      KC_HTTP_RELATIVE_PATH: {{ .keycloakHttpRelativePath }}
      KC_LOG_LEVEL: {{ .keycloakLogLevel }}
      KC_METRICS_ENABLED: "{{ .keycloakMetricsEnabled }}"
      KC_HEALTH_ENABLED: "{{ .keycloakHealthEnabled }}"
    ports:
      - "{{ .keycloakPort }}:8080"
{{ if .modules.postgres.enabled }}
    depends_on:
      postgres:
        condition: service_healthy
{{ end }}
    healthcheck:
      test: ["CMD-SHELL", "exec 3<>/dev/tcp/localhost/8080 && echo -e 'GET /health/ready HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n' >&3 && cat <&3 | grep -q '200 OK'"]
      interval: 20s
      timeout: 10s
      retries: 10
      start_period: 60s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - kc_net
{{ if .modules.postgres.enabled }}
      - db_net
{{ end }}

networks:
  kc_net:
    driver: bridge

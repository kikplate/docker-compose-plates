services:
  portainer:
    image: portainer/portainer-ce:{{ .portainerVersion }}
    container_name: {{ .projectName }}-portainer
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    command:
      - --base-url=/
      - --log-level={{ .portainerLogLevel }}
    ports:
      - "{{ .portainerEdgePort }}:8000"
      - "{{ .portainerPort }}:9000"
      - "{{ .portainerHttpsPort }}:9443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - portainer_data:/data
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:9000/api/system/status"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 15s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

volumes:
  portainer_data:

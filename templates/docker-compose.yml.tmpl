{{ if .modules.mysql.enabled }}
include:
  - docker-compose.mysql.yml
{{ end }}
{{ if .modules.redis.enabled }}
  - docker-compose.redis.yml
{{ end }}
services:
  wordpress:
    image: wordpress:{{ .wordpressVersion }}
    container_name: {{ .projectName }}-wordpress
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    env_file:
      - .env
    environment:
      WORDPRESS_DB_HOST: mysql:3306
      WORDPRESS_DB_USER: ${MYSQL_USER}
      WORDPRESS_DB_PASSWORD: ${MYSQL_PASSWORD}
      WORDPRESS_DB_NAME: ${MYSQL_DATABASE}
      WORDPRESS_TABLE_PREFIX: {{ .wordpressTablePrefix }}
      WORDPRESS_DEBUG: {{ .wordpressDebug }}
      WORDPRESS_CONFIG_EXTRA: |
        define('WP_MEMORY_LIMIT', '{{ .phpMemoryLimit }}');
        @ini_set('upload_max_filesize', '{{ .maxUploadSize }}');
        @ini_set('post_max_size', '{{ .maxUploadSize }}');
{{ if .modules.redis.enabled }}
        define('WP_REDIS_HOST', 'redis');
        define('WP_REDIS_PORT', {{ .redisPort }});
        define('WP_REDIS_PASSWORD', getenv('REDIS_PASSWORD'));
        define('WP_CACHE_KEY_SALT', '{{ .projectName }}:');
        define('WP_CACHE', true);
{{ end }}
    ports:
      - "{{ .wordpressPort }}:80"
    volumes:
      - wordpress_data:/var/www/html
{{ if .modules.mysql.enabled }}
    depends_on:
      mysql:
        condition: service_healthy
{{ end }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - wp_net
{{ if .modules.mysql.enabled }}
      - db_net
{{ end }}
{{ if .modules.redis.enabled }}
      - cache_net
{{ end }}

volumes:
  wordpress_data:

networks:
  wp_net:
    driver: bridge

services:
  loki:
    image: grafana/loki:{{ .lokiVersion }}
    container_name: {{ .projectName }}-loki
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    command: -config.file=/etc/loki/local-config.yaml
    ports:
      - "{{ .lokiPort }}:3100"
    volumes:
      - ./loki-config.yml:/etc/loki/local-config.yaml:ro
      - loki_data:/loki
    healthcheck:
      test: ["CMD-SHELL", "wget --quiet --tries=1 --spider http://localhost:3100/ready || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 15s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - loki_net
{{ if .modules.promtail.enabled }}
  promtail:
    image: grafana/promtail:{{ .promtailVersion }}
    container_name: {{ .projectName }}-promtail
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    command: -config.file=/etc/promtail/config.yml
    volumes:
      - ./promtail-config.yml:/etc/promtail/config.yml:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/log:/var/log:ro
    depends_on:
      loki:
        condition: service_healthy
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - loki_net
{{ end }}
{{ if .modules.grafana.enabled }}
  grafana:
    image: grafana/grafana:{{ .grafanaVersion }}
    container_name: {{ .projectName }}-grafana
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    env_file:
      - .env
    environment:
      GF_SECURITY_ADMIN_USER: ${GRAFANA_ADMIN_USER}
      GF_SECURITY_ADMIN_PASSWORD: ${GRAFANA_ADMIN_PASSWORD}
      GF_USERS_ALLOW_SIGN_UP: "{{ .grafanaAllowSignUp }}"
      GF_LOG_LEVEL: {{ .grafanaLogLevel }}
      GF_PATHS_PROVISIONING: /etc/grafana/provisioning
    ports:
      - "{{ .grafanaPort }}:3000"
    volumes:
      - grafana_data:/var/lib/grafana
    depends_on:
      loki:
        condition: service_healthy
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - loki_net
{{ end }}
volumes:
  loki_data:
{{ if .modules.grafana.enabled }}
  grafana_data:
{{ end }}
networks:
  loki_net:
    driver: bridge

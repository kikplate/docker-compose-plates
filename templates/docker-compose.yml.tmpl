{{ if .modules.postgres.enabled }}
include:
  - docker-compose.postgres.yml
{{ end }}
{{ if .modules.redis.enabled }}
  - docker-compose.redis.yml
{{ end }}
services:
  n8n:
    image: n8nio/n8n:{{ .n8nVersion }}
    container_name: {{ .projectName }}-n8n
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    env_file:
      - .env
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_PORT: 5432
      DB_POSTGRESDB_DATABASE: ${POSTGRES_DB}
      DB_POSTGRESDB_USER: ${POSTGRES_USER}
      DB_POSTGRESDB_PASSWORD: ${POSTGRES_PASSWORD}
      N8N_BASIC_AUTH_ACTIVE: "true"
      N8N_BASIC_AUTH_USER: ${N8N_BASIC_AUTH_USER}
      N8N_BASIC_AUTH_PASSWORD: ${N8N_BASIC_AUTH_PASSWORD}
      N8N_ENCRYPTION_KEY: ${N8N_ENCRYPTION_KEY}
      GENERIC_TIMEZONE: {{ .n8nTimezone }}
      N8N_HOST: {{ .n8nHost }}
      N8N_PROTOCOL: {{ .n8nProtocol }}
      EXECUTIONS_PROCESS: {{ .execProcessMode }}
      EXECUTIONS_TIMEOUT: {{ .execTimeout }}
      N8N_PAYLOAD_SIZE_MAX: {{ .n8nPayloadSizeMax }}
{{ if .modules.redis.enabled }}
      EXECUTIONS_MODE: queue
      QUEUE_BULL_REDIS_HOST: redis
      QUEUE_BULL_REDIS_PORT: {{ .redisPort }}
      QUEUE_BULL_REDIS_PASSWORD: ${REDIS_PASSWORD}
{{ end }}
    ports:
      - "{{ .n8nPort }}:5678"
    volumes:
      - n8n_data:/home/node/.n8n
{{ if .modules.postgres.enabled }}
    depends_on:
      postgres:
        condition: service_healthy
{{ end }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - n8n_net
{{ if .modules.postgres.enabled }}
      - db_net
{{ end }}
{{ if .modules.redis.enabled }}
      - cache_net
{{ end }}

volumes:
  n8n_data:

networks:
  n8n_net:
    driver: bridge

services:
  mariadb:
    image: mariadb:{{ .mariadbVersion }}
    container_name: {{ .projectName }}-mariadb
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    env_file:
      - .env
    environment:
      MARIADB_ROOT_PASSWORD: ${MARIADB_ROOT_PASSWORD}
      MARIADB_DATABASE: ${MARIADB_DATABASE}
      MARIADB_USER: ${MARIADB_USER}
      MARIADB_PASSWORD: ${MARIADB_PASSWORD}
    command: >
      --character-set-server={{ .mariadbCharset }}
      --collation-server={{ .mariadbCollation }}
      --skip-name-resolve
    ports:
      - "{{ .mariadbPort }}:3306"
    volumes:
      - mariadb_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - db_net
{{ if .modules.phpmyadmin.enabled }}
  phpmyadmin:
    image: phpmyadmin:{{ .phpmyadminVersion }}
    container_name: {{ .projectName }}-phpmyadmin
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    environment:
      PMA_HOST: mariadb
      PMA_PORT: 3306
      PMA_ARBITRARY: 0
      UPLOAD_LIMIT: 64M
    ports:
      - "{{ .phpmyadminPort }}:80"
    depends_on:
      mariadb:
        condition: service_healthy
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - db_net
{{ end }}
volumes:
  mariadb_data:

networks:
  db_net:
    driver: bridge

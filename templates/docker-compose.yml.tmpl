services:
  nginx:
    image: nginx:{{ .nginxVersion }}
    container_name: {{ .projectName }}-nginx
    restart: unless-stopped
    ports:
      - "{{ .proxyPort }}:80"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    healthcheck:
      test: ["CMD-SHELL", "wget --quiet --tries=1 --spider http://localhost/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - proxy_net

networks:
  proxy_net:
    driver: bridge

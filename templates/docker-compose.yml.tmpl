services:
{{ if .modules.postgres.enabled }}
  postgres:
    image: postgres:{{ .postgresVersion }}-alpine
    container_name: {{ .projectName }}-postgres
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    env_file:
      - .env
    environment:
      POSTGRES_USER: n8n
      POSTGRES_PASSWORD: ${DB_POSTGRESDB_PASSWORD}
      POSTGRES_DB: n8n
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U n8n -d n8n"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - n8n_net

{{ end }}
  n8n:
    image: n8nio/n8n:{{ .n8nVersion }}
    container_name: {{ .projectName }}-n8n
    restart: unless-stopped
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    env_file:
      - .env
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_PORT: 5432
      DB_POSTGRESDB_DATABASE: n8n
      DB_POSTGRESDB_USER: n8n
      DB_POSTGRESDB_PASSWORD: ${DB_POSTGRESDB_PASSWORD}
      N8N_BASIC_AUTH_ACTIVE: "true"
      N8N_BASIC_AUTH_USER: ${N8N_BASIC_AUTH_USER}
      N8N_BASIC_AUTH_PASSWORD: ${N8N_BASIC_AUTH_PASSWORD}
      N8N_ENCRYPTION_KEY: ${N8N_ENCRYPTION_KEY}
      GENERIC_TIMEZONE: {{ .n8nTimezone }}
      N8N_HOST: {{ .n8nHost }}
      N8N_PROTOCOL: {{ .n8nProtocol }}
      EXECUTIONS_PROCESS: {{ .execProcessMode }}
      EXECUTIONS_TIMEOUT: {{ .execTimeout }}
      N8N_PAYLOAD_SIZE_MAX: {{ .n8nPayloadSizeMax }}
    ports:
      - "{{ .n8nPort }}:5678"
    volumes:
      - n8n_data:/home/node/.n8n
{{ if .modules.postgres.enabled }}
    depends_on:
      postgres:
        condition: service_healthy
{{ end }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - n8n_net

volumes:
  n8n_data:
{{ if .modules.postgres.enabled }}
  postgres_data:
{{ end }}
networks:
  n8n_net:
    driver: bridge

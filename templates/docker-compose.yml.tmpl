services:
  vault:
    image: hashicorp/vault:{{ .vaultVersion }}
    container_name: {{ .projectName }}-vault
    restart: unless-stopped
    env_file:
      - .env
    environment:
      VAULT_DEV_ROOT_TOKEN_ID: ${VAULT_DEV_ROOT_TOKEN_ID}
      VAULT_DEV_LISTEN_ADDRESS: 0.0.0.0:8200
      VAULT_ADDR: http://127.0.0.1:8200
    ports:
      - "{{ .vaultPort }}:8200"
    cap_add:
      - IPC_LOCK
    healthcheck:
      test: ["CMD", "vault", "status"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 5s
    networks:
      - vault_net

networks:
  vault_net:
    driver: bridge
